# Copy to `.env` (next to docker-compose.yml or docker-compose.prod.yml) and set values. Incoming webhook URL (no trailing slash).
# Production (optional): override image from GHCR if you fork the repo:
# CRM_LAYER_IMAGE=ghcr.io/your-org/crm_layer:main
# https://apidocs.bitrix24.com/ — local integrations → incoming webhook
BITRIX24_WEBHOOK_BASE_URL=https://your-portal.bitrix24.pl/rest/1/your-webhook-token
# Optional: GitHub PAT for `docker compose exec crm-layer gh …` without interactive login (repo scope).
# GH_TOKEN=
